########################################
# DockGo Environment Configuration
########################################

########################
# Server Configuration
########################

# Port DockGo listens on inside the container.
# Must match the container-side port in docker-compose.
PORT=3131

# Allowed CORS origin.
# Change in production to your frontend origin.
CORS_ORIGIN=http://localhost:3131


########################
# Authentication
########################

# --- Option 1: Legacy API Token ---
# API_TOKEN=replace_with_strong_random_token


# --- Option 2: User Login (Recommended) ---
# AUTH_USERNAME=admin

# Development convenience (NOT recommended for production):
# AUTH_PASSWORD=replace_with_strong_password

# Production recommended approach:
# Pre-hash your password using:
#   dockgo hash-password yourpassword
#
# NOTE:
# If using docker-compose inline environment variables,
# escape '$' as '$$'.
#
# AUTH_PASSWORD_HASH=$2a$10$examplehashedpasswordstring

# Required when using username/password authentication.
# Used to sign session cookies.
# Generate with:
#   openssl rand -hex 32
#
# AUTH_SECRET=replace_with_random_secret

# Optional bcrypt cost (default: 10)
# AUTH_BCRYPT_COST=10


########################
# Compose Security
########################

# Restrict Compose working directories.
# Comma-separated list of allowed base paths.
#
# Example:
# ALLOWED_COMPOSE_PATHS=/opt/docker,/home/user/docker
#
# ALLOWED_COMPOSE_PATHS=

# Map Windows/Host paths to mounted container paths for Compose projects.
# Required if running DockGo on Windows and managing Compose projects.
# Format: HOST_PATH:CONTAINER_PATH
# Example:
# COMPOSE_PATH_MAPPING=D:\Docker:/compose
#
# COMPOSE_PATH_MAPPING=


########################
# Notifications (Apprise)
########################

# Example:
# APPRISE_URL=ntfy://token@host/topic
#
# Optional queue size (default: 200)
# APPRISE_QUEUE_SIZE=200


########################
# Background Scan Schedule
########################

# How often DockGo checks for updates.
# Examples: 12h, 30m, 6h
SCAN_INTERVAL=24h


########################
# Orchestrator Settings
########################

# Grace period before force-stopping container (seconds)
# DOCKGO_STOP_TIMEOUT=10

# Max wait time for a container to become healthy (seconds)
# DOCKGO_HEALTH_TIMEOUT=60

# Initial runtime check for containers without healthchecks (seconds)
# DOCKGO_INITIAL_RUNTIME_CHECK=10

# Stability monitoring window post-healthcheck (seconds)
# DOCKGO_STABILITY_WINDOW=20


########################
# Logging
########################

# LOG_FORMAT=json
# LOG_LEVEL=info
# DOCKGO_DEBUG=false