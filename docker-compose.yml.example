---
services:
  dockgo:
    build: .
    container_name: dockgo
    restart: unless-stopped

    # Expose DockGo on the host
    # Left side = host port
    # Right side = container port (must match PORT in .env)
    ports:
      - "${PORT:-3131}:${PORT:-3131}"

    # Load environment variables from .env file
    env_file:
      - .env

    # environment:
      # Only set COMPOSE_PATH_MAPPING when DockGo sees Compose projects at a
      # different path than the Docker host.
      #
      # Windows example:
      # - COMPOSE_PATH_MAPPING=D:\Docker:/compose
      #
      # Linux example only if you intentionally mount to a different internal path:
      # - COMPOSE_PATH_MAPPING=/home/user/docker:/compose

    volumes:
      # Required: Docker socket access for container discovery and updates.
      # WARNING: Grants Docker-level privileges to DockGo.
      - /var/run/docker.sock:/var/run/docker.sock

      # Required: Persistent data (sessions, cache, etc.)
      - ./data:/app/data

      # Compose stacks on Linux: prefer mounting the compose root at the exact
      # same absolute path as the host, then use "Host Native" in DockGo.
      # - /home/user/docker:/home/user/docker

      # Compose stacks on Windows, or any setup where DockGo sees a different
      # path than the host: mount to an internal path and use "Mapped" in DockGo
      # together with COMPOSE_PATH_MAPPING.
      # - /home/user/docker:/compose
      # - D:\Docker:/compose
      
  ########################################
  # Optional: Apprise API Container
  ########################################
  # apprise:
  #   image: caronc/apprise
  #   container_name: apprise
  #   restart: unless-stopped
  #   ports:
  #     - "4747:8000"
  #   environment:
  #     - APPRISE_WORKER_COUNT=2
